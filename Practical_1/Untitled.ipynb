   "outputs": [
    {
     "data": {
      "text/plain": [
       "array([[ 3,  0,  8],\n",
       "       [ 0,  8,  0],\n",
       "       [ 8,  0, 32]])"
      ]
     },
     "execution_count": 27,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "x = np.array([-2, 0, 2])\n",
    "Phi = np.column_stack((np.ones_like(x), x, x ** 2))\n",
    "\n",
    "Phi.T @ Phi"
   ]
  },
